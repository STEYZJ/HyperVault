VAULT_PATH=knowledge-vault
RUNTIME_PATH=runtime

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hypervault_chunks

OPENAI_API_KEY=
OPENAI_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
OFFLINE_TEST_EMBEDDINGS=false

STRATEGY_LLM_PROVIDER=openai
STRATEGY_LLM_MODEL=gpt-4o-mini
STRATEGY_EXTRACTION_TEMPERATURE=0.2
STRATEGY_MAX_EVIDENCE_ITEMS=80
STRATEGY_LLM_MAX_RETRIES=2
VISION_PROVIDER=none
VISION_MODEL=
EXPORT_FIGURE_PAGES=false

# Optional external integration. HyperVault never imports HyperAgent Python packages.
# HYPERAGENT_CLI=/data2/lzj/HyperAgent/HyperAgent
# HYPERAGENT_WORKDIR=/data2/lzj/HyperAgent
# HYPERAGENT_COMMAND_TEMPLATE=
HYPERAGENT_TIMEOUT_SECONDS=120

INDEX_BATCH_SIZE=64
CHUNK_TARGET_CHARS=1600
CHUNK_OVERLAP_CHARS=220
WATCH_DEBOUNCE_SECONDS=1.5

API_HOST=0.0.0.0
API_PORT=8088
LOG_LEVEL=INFO
